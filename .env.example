# Copy this file to .env and fill in your values
# cp .env.example .env

# Your EVM wallet private key (without 0x prefix)
WALLET_PRIVATE_KEY=

# (Optional) Your wallet address. If not set, derived from private key.
# WALLET_ADDRESS=0xYourWalletAddress

# (Optional) RPC URL. Default: https://sepolia.drpc.org
# RPC_URL=https://sepolia.drpc.org

# (Optional) Gas price in Gwei. Default: 3
# GAS_PRICE_GWEI=3
